# SportShield AI - Google Solution Challenge 2026
# Backend Environment Configuration

# 1. Gemini API Key (Required for Multimodal AI and Summaries)
# Get this from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Firebase Project Information
# Get this from Firebase Console -> Project Settings -> General
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# 3. Google Custom Search Engine (For Web Crawling/Theft Detection)
# Get from: https://developers.google.com/custom-search/v1/overview
GOOGLE_CSE_KEY=your_google_cse_api_key_here
GOOGLE_CSE_CX=your_google_cse_search_engine_id_here

# 4. DMCA Email Settings
# Get from: https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_verified_sender_email@domain.com

# 5. Service Account Key (IMPORTANT: For local dev, use the file path)
FIREBASE_CREDENTIALS_JSON=./serviceAccountKey.json

# 6. Optional Local Settings
DEMO_MODE=true
PORT=8000
